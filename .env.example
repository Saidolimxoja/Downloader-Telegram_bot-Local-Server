# === BOT ===
BOT_TOKEN=your_bot_token_from_botfather
YOUR_USERNAME=@your_bot_username
API_URL=http://localhost:8081

# === TELEGRAM API (для локального сервера) ===
API_ID=your_api_id_from_my_telegram_org
API_HASH=your_api_hash_from_my_telegram_org

SESSION_STRING=  # Пока пусто, получим позже

# === CHANNELS ===
CHANNEL_ID=Your_channel_id_for_archive  # Канал для архива (должен быть числовой ID)


# === DATABASE (Supabase) ===
# Получи строку подключения из Supabase Dashboard -> Project Settings -> Database -> Connection string (URI)
# Пример: postgresql://postgres:YOUR_PASSWORD@db.xxxxxxxxxxxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxxxxxxxxxxx.supabase.co:5432/postgres

# === REDIS ===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# === APP ===
NODE_ENV=development
PORT=3000

# === PATHS ===
YTDLP_PATH=yt-dlp  # Или полный путь: /usr/local/bin/yt-dlp
DOWNLOADS_DIR=./downloads

# === QUEUE ===
MAX_PARALLEL_DOWNLOADS=3