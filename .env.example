# === BOT ===
BOT_TOKEN=your_bot_token_from_botfather
YOUR_USERNAME=@your_bot_username

SESSION_STRING=  # Пока пусто, получим позже

# === CHANNELS ===
CHANNEL_ID=Your_channel_id_for_archive  # Канал для архива (должен быть числовой ID)


# === DATABASE ===
DATABASE_URL=your_database_URL

# === APP ===
NODE_ENV=development
PORT=3000

# === PATHS ===
YTDLP_PATH=yt-dlp  # Или полный путь: /usr/local/bin/yt-dlp
DOWNLOADS_DIR=./downloads

# === QUEUE ===
MAX_PARALLEL_DOWNLOADS=3